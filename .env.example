# Подключение к БД. Локально — local Postgres, на сервере — строка серверной БД.
# Таблица listings та же, что у Авито (source="cian").
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram-уведомления (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Мобильный ротационный прокси
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_ROTATE_URL=
